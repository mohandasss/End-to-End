# Copy to .env and fill the values before running the app
# Use either an accelerate URL (recommended for Rust-free operation) or a normal connection string + adapter

# Example accelerate URL (prisma:// or prisma+postgres://)
# PRISMA_ACCELERATE_URL=prisma://<api_key>@<host>

# Or use a database connection string and an adapter package (e.g., @prisma/adapter-planetscale)
# DATABASE_URL="mysql://user:password@host:3306/dbname"

# Notes:
# - DO NOT commit secrets into version control. Use environment variables or a secrets manager.
# - If using an adapter, install and configure it as shown below.
#   Example (Planetscale adapter):
#     npm install @prisma/adapter-planetscale
#     const { PrismaPlanetscale } = require('@prisma/adapter-planetscale')
#     const adapter = new PrismaPlanetscale({ connectionString: process.env.DATABASE_URL })
#     const prisma = new PrismaClient({ adapter })
